generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WebhookEvent {
  id           String   @id @default(uuid())
  eventId      String   @unique @map("event_id")
  source       String
  processedAt  DateTime @default(now()) @map("processed_at")
  orderId      String?  @map("order_id")

  @@map("webhook_events")
}
