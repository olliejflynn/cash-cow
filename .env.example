# API
# Local dev: 3000 is fine.
# Railway: do NOT set PORT in the dashboard—Railway injects PORT automatically. Listening on
# the wrong port causes 502. WooCommerce sends large JSON bodies; default Express limit was
# raised in code (50mb); override with REQUEST_BODY_LIMIT if needed.
PORT=3000
WEBHOOK_SECRET=your-shared-secret

# Database (PostgreSQL) – used by API and migrations
# For local Docker: postgresql://cashcow:cashcow@localhost:5432/cash_cow
DATABASE_URL=postgresql://user:password@localhost:5432/cash_cow

# -----------------------------------------------------------------------------
# Google Cloud → Google Sheets (service account, not an API key)
# -----------------------------------------------------------------------------
# In Google Cloud Console (pick or create a project):
#   1. APIs & Services → Library → enable "Google Sheets API".
#   2. IAM & Admin → Service accounts → Create service account (name is arbitrary).
#   3. Open that service account → Keys → Add key → Create new key → JSON.
#      (This JSON is different from "APIs & Services → Credentials → API key".)
#   4. Open the downloaded JSON: copy "client_email" and share your Google Sheet
#      with that address as Editor.
#
# Provide credentials using exactly ONE of the two variables below:
#   - GOOGLE_SERVICE_ACCOUNT_PATH: path to the .json file (typical locally; can be absolute).
#   - GOOGLE_SERVICE_ACCOUNT_JSON: entire JSON object as ONE line (typical on Railway).
# Do not paste multiline JSON into .env — parsers break and JSON.parse will fail.
# In a .env file, do not wrap that JSON in extra double quotes (GOOGLE_SERVICE_ACCOUNT_JSON="{...}")
# — the first inner " ends the string. Use either: JSON={"type":...} with no outer quotes, or
# escape every inner quote as \", or keep credentials in a file and use PATH only locally.
# Never commit real keys or check them into git.
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_PATH=/absolute/path/to/your-service-account-key.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"name@project.iam.gserviceaccount.com",...}

# Target spreadsheet: ID from the URL
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your-spreadsheet-id
SALES_LOG_SHEET_NAME=Sales_Log
# Tab with columns Ticket_type_Slug, Commission (used when appending Sales_Log rows)
TICKET_RULES_SHEET_NAME=Ticket_rules
SQUARE_PAYMENTS_SHEET_NAME=Square_payments
M_SQUARE_PAYMENTS_SHEET_NAME=M Square_payments
# Square webhooks: map team_member_id -> user_id (seller code) via headers user_id, email, Square_team_ID, M Square_team_ID
SQUARE_IDS_SHEET_NAME=Square IDs

# Telegram /all: cash-in tabs (seller id column A; hand in C, card D, cash in E). Defaults include emoji.
# L_CASH_IN_SHEET_NAME=L CASH IN 🍻
# M_CASH_IN_SHEET_NAME=M CASH IN 👑

# Users tab (WordPress users + Square team id by email). Tab is created if missing.
USERS_SHEET_NAME=users
# -----------------------------------------------------------------------------
# WordPress REST API (read users → Users sheet during `npm run build`)
# -----------------------------------------------------------------------------
# Site base URL with no trailing slash. If WORDPRESS_SITE_URL is unset, WOOCOMMERCE_SITE_URL is used.
WORDPRESS_SITE_URL=https://your-shop.example.com
# WOOCOMMERCE_SITE_URL=https://your-shop.example.com
#
# Users → Profile → Application Passwords: create a password for this app.
# The WP user must be able to list users (e.g. Administrator). Auth is HTTP Basic:
#   username = WordPress username (login slug)
#   password = the generated application password (including spaces if WP shows them)
WORDPRESS_REST_USERNAME=
WORDPRESS_REST_APPLICATION_PASSWORD=

# Bearer token for POST /internal/sync-users-sheet (manual refresh). Generate e.g. openssl rand -hex 32
USERS_SHEET_SYNC_SECRET=

# MVP defaults (no Ticket_Rules/Seller_Overrides yet)
DEFAULT_HAND_IN_PERCENT=100
DEFAULT_SELLER_CODE=UNKNOWN

# -----------------------------------------------------------------------------
# Square OAuth (server-side authorization code flow)
# -----------------------------------------------------------------------------
# Application credentials from Square Developer Dashboard → Your application → OAuth.
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
# Must match a redirect URL configured for the application (e.g. https://your-host/oauth/square/callback).
SQUARE_REDIRECT_URI=http://localhost:3000/oauth/square/callback
# sandbox | production (controls connect.squareup.com vs connect.squareupsandbox.com).
SQUARE_ENVIRONMENT=sandbox
# Space-separated Square permission names. If empty, defaults to MERCHANT_PROFILE_READ PAYMENTS_READ.
# SQUARE_OAUTH_SCOPES=MERCHANT_PROFILE_READ PAYMENTS_READ
# Route incoming Square webhooks by merchant_id:
# - payload merchant_id matching SQUARE_PRIMARY_MERCHANT_ID -> Square_payments flow
# - payload merchant_id matching SQUARE_M_MERCHANT_ID -> M Square_payments flow
SQUARE_PRIMARY_MERCHANT_ID=
SQUARE_M_MERCHANT_ID=
# Long random secret used to encrypt tokens at rest (AES-256-GCM) and to sign OAuth state (CSRF).
# Generate e.g. openssl rand -base64 48
SQUARE_TOKEN_ENCRYPTION_KEY=
# Optional. If set, GET /oauth/square/authorize-url requires Authorization: Bearer <this value>.
# SQUARE_OAUTH_SETUP_SECRET=

# -----------------------------------------------------------------------------
# Telegram bot (webhook → POST /telegram/webhook)
# -----------------------------------------------------------------------------
# Token from @BotFather. Never commit the real value.
TELEGRAM_BOT_TOKEN=
# Optional locally: if empty, the webhook does not require X-Telegram-Bot-Api-Secret-Token.
# In production, set this and pass the same value as secret_token when calling setWebhook.
# Generate e.g. openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
#
# After deploy, register the webhook (HTTPS URL must match your public host):
#   curl -sS "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/setWebhook" \
#     -d "url=https://YOUR_PUBLIC_HOST/telegram/webhook" \
#     -d "secret_token=${TELEGRAM_WEBHOOK_SECRET}" \
#     -d "drop_pending_updates=true"
# Verify: curl -sS "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getWebhookInfo"
